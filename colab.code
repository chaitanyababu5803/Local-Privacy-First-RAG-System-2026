# 1. INSTALL DEPENDENCIES
# Using --quiet to speed up output and keep the notebook clean
!curl -fsSL https://ollama.com/install.sh | sh
!pip install -q chromadb langchain langchain-community langchain-text-splitters sentence-transformers gradio pypdf langchain-ollama

import subprocess, time, os, gradio as gr
from langchain_community.document_loaders import PyPDFLoader, TextLoader
from langchain_community.embeddings import HuggingFaceEmbeddings
from langchain_community.vectorstores import Chroma
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_ollama import OllamaLLM

# 2. START OLLAMA SERVER (Background)
# Redirecting output to /dev/null keeps the notebook responsive
subprocess.Popen(['nohup', 'ollama', 'serve'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
time.sleep(10) 

# Pull the model once
print("🚀 Downloading Llama 3.2 1B (optimized for speed)...")
!ollama pull llama3.2:1b

# 3. RAG ENGINE
# Using a lightweight, fast embedding model
embeddings = HuggingFaceEmbeddings(model_name="all-MiniLM-L6-v2")
vector_db = None

def process_file(file):
    global vector_db
    loader = PyPDFLoader(file.name) if file.name.endswith('.pdf') else TextLoader(file.name)
    
    # Moderate chunk size balances speed and context retention
    text_splitter = RecursiveCharacterTextSplitter(chunk_size=500, chunk_overlap=100)
    chunks = text_splitter.split_documents(loader.load())
    
    if vector_db: vector_db.delete_collection()
        
    vector_db = Chroma.from_documents(documents=chunks, embedding=embeddings)
    return f"✅ Indexed {len(chunks)} chunks. System ready."

def ask_llama(question):
    if not vector_db: return "⚠️ Please upload a document first."
    
    docs = vector_db.similarity_search(question, k=3) # Reduced k for faster retrieval
    context = "\n---\n".join([d.page_content for d in docs])
    
    # Using the Llama 3.2 1B model (fastest local option)
    llm = OllamaLLM(model="llama3.2:1b")
    
    prompt = f"Context: {context}\n\nQuestion: {question}\n\nAnswer concisely based on the context."
    return llm.invoke(prompt)

# 4. UI
with gr.Blocks(theme=gr.themes.Soft()) as demo:
    gr.Markdown("# ⚡ Fast Precision RAG")
    with gr.Row():
        file_input = gr.File(label="Upload PDF/TXT")
        btn_index = gr.Button("Index Data", variant="primary")
    chat_input = gr.Textbox(label="Ask a Question")
    chat_output = gr.Textbox(label="AI Response", interactive=False)
    
    btn_index.click(process_file, [file_input], [chat_output])
    chat_input.submit(ask_llama, [chat_input], [chat_output])

demo.launch(share=True)
